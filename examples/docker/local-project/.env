# ========================================
# Local Project Mode Configuration
# ========================================

# Server Configuration
GHIDRA_MCP_HOST=0.0.0.0
GHIDRA_MCP_PORT=8803
GHIDRA_MCP_SSE_PORT=8804

# Project Configuration
PROJECT_MODE=local

# IMPORTANT: Update this to your actual Ghidra project path on the host
# Example: /Users/username/ghidra-projects/my_binary
HOST_PROJECT_PATH=/path/to/your/ghidra-project

# Project directory inside container (usually don't change this)
PROJECT_PATH=/ghidra-projects

# IMPORTANT: Update this to match your project name
# This should match the .gpr and .rep directory name in your project folder
PROJECT_NAME=my_binary_project

# Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs
