# ========================================
# Ghidra MCP Bridge Configuration
# ========================================

# -------------------- Server Configuration --------------------
GHIDRA_MCP_HOST=0.0.0.0          # Use 0.0.0.0 in Docker, 127.0.0.1 for local
GHIDRA_MCP_PORT=8803             # HTTP API port
GHIDRA_MCP_SSE_PORT=8804         # MCP SSE port

# -------------------- Project Configuration --------------------
# Project mode: local | server
PROJECT_MODE=local

# Local project configuration (PROJECT_MODE=local)
PROJECT_PATH=/ghidra-projects          # Project directory (Docker mount point)
PROJECT_NAME=my_binary_project         # Project name

# Ghidra Server configuration (PROJECT_MODE=server)
GHIDRA_SERVER_HOST=ghidra-server.local
GHIDRA_SERVER_PORT=13100
GHIDRA_SERVER_USER=analyst
GHIDRA_SERVER_REPO=/shared             # Server repository path
# GHIDRA_SERVER_PASSWORD=secret        # Not recommended for plaintext, use Docker secrets

# -------------------- Analysis Configuration --------------------
AUTO_ANALYZE=false               # Auto-analyze on startup (headless mode)
ANALYZE_TIMEOUT=3600             # Analysis timeout (seconds)

# -------------------- Logging Configuration --------------------
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_DIR=/app/logs                # Log directory (Docker mount volume)
