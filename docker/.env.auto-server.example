# Ghidra MCP Bridge - Auto-Server Mode Configuration
# This is a pre-configured example for auto-server deployment
# Copy this file to .env and adjust as needed

# ============================================
# Project Configuration - Auto-Server Mode
# ============================================

# Project mode: Set to 'auto-server' to deploy bundled Ghidra Server
PROJECT_MODE=auto-server

# Host path to store Ghidra binaries and data
# This directory will be used for importing binaries into the project
HOST_PROJECT_PATH=/path/to/your/binaries

# Project name (binaries will be imported into this project)
PROJECT_NAME=my_analysis

# ============================================
# Server Configuration
# ============================================

# HTTP API port
GHIDRA_MCP_PORT=8803

# MCP SSE proxy port
GHIDRA_MCP_SSE_PORT=8804

# ============================================
# Auto-Server Configuration
# ============================================

# SSH keys directory (will be created automatically if not exists)
# Default: ~/.ghidra (on host)
AUTO_SERVER_SSH_DIR=~/.ghidra

# Default repository name on the server
AUTO_SERVER_REPO=/mcp-projects

# Default user name
AUTO_SERVER_USER=bridge

# Server resource limits
GHIDRA_SERVER_MAXMEM=4G

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Advanced Options
# ============================================

# Auto-analyze binaries on import (true/false)
# AUTO_ANALYZE=false

# Analysis timeout in seconds
# ANALYZE_TIMEOUT=3600

# ============================================
# Notes
# ============================================
# After starting with 'make up-separated':
#
# 1. Server connection info:
#    - Server: localhost:13100
#    - User: bridge
#    - SSH Key: ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/ssh/ssh_key
#    - Repository: /mcp-projects
#
# 2. Connect Ghidra GUI:
#    - File → New Project → Shared Project
#    - Enter server details above
#    - Now AI (Docker) and GUI (you) can work simultaneously!
#
# 3. Import binaries:
#    - In Ghidra GUI: File → Import File
#    - Or use API: POST /api/v1/edit (future feature)
