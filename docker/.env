# Ghidra MCP Bridge - Server Mode Configuration

# ============================================
# Project Configuration
# ============================================

# Project mode: 'server' to connect to Ghidra Server
PROJECT_MODE=server

# Project name on server (optional, will list if not specified)
PROJECT_NAME=test_project

# ============================================
# Ghidra Server Configuration
# ============================================

# Server host (use 127.0.0.1 with host networking mode)
GHIDRA_SERVER_HOST=127.0.0.1

# Server port
GHIDRA_SERVER_PORT=13100

# Server user (leave empty for anonymous)
GHIDRA_SERVER_USER=

# Server password (if required)
GHIDRA_SERVER_PASSWORD=

# Repository name (leave empty to use first available)
GHIDRA_SERVER_REPO=

# ============================================
# Server Configuration
# ============================================

# HTTP API port
GHIDRA_MCP_PORT=8803

# MCP SSE proxy port
GHIDRA_MCP_SSE_PORT=8804

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
