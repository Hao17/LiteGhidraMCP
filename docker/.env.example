# Ghidra MCP Bridge - PyGhidra Edition
# Environment Variables Configuration

# ============================================
# Project Configuration
# ============================================

# Host path to your Ghidra project directory
# This directory should contain:
#   - <PROJECT_NAME>.gpr (project file)
#   - <PROJECT_NAME>.rep/ (project repository)
HOST_PROJECT_PATH=/path/to/your/ghidra-project

# Ghidra project name (must match .gpr filename without extension)
PROJECT_NAME=my_binary

# Project mode: 'local' or 'server'
PROJECT_MODE=local

# ============================================
# Server Configuration
# ============================================

# HTTP API port
GHIDRA_MCP_PORT=8803

# MCP SSE proxy port
GHIDRA_MCP_SSE_PORT=8804

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Ghidra Server Mode (optional)
# ============================================
# Only used when PROJECT_MODE=server

# GHIDRA_SERVER_HOST=ghidra-server.local
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=analyst
# GHIDRA_SERVER_REPO=/
# GHIDRA_SERVER_PASSWORD=changeme

# ============================================
# Advanced Options
# ============================================

# Auto-analyze binaries on import (true/false)
# AUTO_ANALYZE=false

# Analysis timeout in seconds
# ANALYZE_TIMEOUT=3600
