# Ghidra MCP Bridge
# Environment Variables Configuration

# ============================================
# Project Configuration
# ============================================

# Host path to your Ghidra project directory
# This directory should contain:
#   - <PROJECT_NAME>.gpr (project file)
#   - <PROJECT_NAME>.rep/ (project repository)
HOST_PROJECT_PATH=/path/to/your/ghidra-project

# Ghidra project name (must match .gpr filename without extension)
PROJECT_NAME=my_binary

# Project mode: 'local' or 'server'
PROJECT_MODE=local

# ============================================
# Server Configuration
# ============================================

# HTTP API port
GHIDRA_MCP_PORT=8803

# MCP SSE proxy port
GHIDRA_MCP_SSE_PORT=8804

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Ghidra Server Mode (optional)
# ============================================
# Only used when PROJECT_MODE=server

# --- Example 1: Docker 启动 Ghidra Server（推荐） ---
# Use this when you want Docker Compose to start a new Ghidra Server
# See docker-compose example in README.md

# PROJECT_MODE=server
# GHIDRA_SERVER_HOST=ghidra-server  # Container name from docker-compose
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=ai_analyst
# GHIDRA_SERVER_REPO=/shared
# GHIDRA_SERVER_PASSWORD=  # Leave empty if using SSH key auth
# GHIDRA_SERVER_KEYSTORE=/root/.ghidra/ssh_key  # Path to SSH private key

# --- Example 2: 连接已有 Ghidra Server ---
# Use this when you have an existing Ghidra Server running elsewhere

# PROJECT_MODE=server
# GHIDRA_SERVER_HOST=192.168.1.100  # Your server IP/hostname
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=my_user
# GHIDRA_SERVER_REPO=/my_repo
# GHIDRA_SERVER_PASSWORD=  # Leave empty if using SSH key
# GHIDRA_SERVER_KEYSTORE=/root/.ghidra/my_key  # Path to your SSH key

# ============================================
# Advanced Options
# ============================================

# Auto-analyze binaries on import (true/false)
# AUTO_ANALYZE=false

# Analysis timeout in seconds
# ANALYZE_TIMEOUT=3600
