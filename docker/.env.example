# Ghidra MCP Bridge
# Environment Variables Configuration

# ============================================
# 版本隔离存储配置（推荐）
# ============================================
# 数据存储根目录（必须配置用于 Server/Client 模式）
# 推荐位置：
#   - macOS:   ~/ghidra-data
#   - Linux:   ~/ghidra-data 或 /opt/ghidra-data
#   - Windows: C:/ghidra-data
GHIDRA_DATA_DIR=~/ghidra-data

# 当前使用的 Ghidra 版本（需与 Dockerfile 中版本一致）
GHIDRA_VERSION=12.0.3

# 实际使用的数据路径（自动生成）：
#   Server Repos:    ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/repos
#   Server Config:   ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/config
#   Client Config:   ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/client-config
#   SSH Keys:        ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/ssh
#   Logs:            ${GHIDRA_DATA_DIR}/logs/${GHIDRA_VERSION}

# ============================================
# Project Configuration
# ============================================

# Host path to your Ghidra project directory
# This directory should contain:
#   - <PROJECT_NAME>.gpr (project file)
#   - <PROJECT_NAME>.rep/ (project repository)
HOST_PROJECT_PATH=/path/to/your/ghidra-project

# Ghidra project name (must match .gpr filename without extension)
PROJECT_NAME=my_binary

# Project mode: 'local' or 'server'
PROJECT_MODE=local

# ============================================
# Server Configuration
# ============================================

# HTTP API port
GHIDRA_MCP_PORT=8803

# MCP SSE proxy port
GHIDRA_MCP_SSE_PORT=8804

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Ghidra Server Configuration (Separated Mode)
# ============================================
# Server 配置（用于 docker-compose.server.yml）
GHIDRA_SERVER_PORT=13100
GHIDRA_SERVER_MAXMEM=4G

# Server 自动初始化配置
SERVER_REPO_NAME=/mcp-projects
SERVER_USER_NAME=bridge

# ============================================
# Ghidra Server Mode (optional)
# ============================================
# Only used when PROJECT_MODE=server

# --- Scenario 1: Auto-deployed Server (docker-compose.with-server.yml) ---
# Easiest setup - server is deployed automatically

# PROJECT_MODE=server  # Set automatically by docker-compose.with-server.yml
# GHIDRA_SERVER_HOST=ghidra-mcp-server  # Container name (auto-set)
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=  # Leave empty for anonymous access (recommended)
# GHIDRA_SERVER_REPO=/default
# GHIDRA_SERVER_PASSWORD=
# GHIDRA_SERVER_KEYSTORE=

# --- Scenario 2: Connect to Existing Ghidra Server ---
# Use this when you have a manually deployed Ghidra Server

# PROJECT_MODE=server
# GHIDRA_SERVER_HOST=192.168.1.100  # Your server IP/hostname
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=my_user
# GHIDRA_SERVER_REPO=/my_repo
# GHIDRA_SERVER_PASSWORD=  # Leave empty if using SSH key
# GHIDRA_SERVER_KEYSTORE=/root/.ghidra/my_key  # Path to your SSH key

# --- Scenario 3: Docker-started Server with SSH Auth (Advanced) ---
# Use when you need authenticated access to auto-deployed server

# PROJECT_MODE=server
# GHIDRA_SERVER_HOST=ghidra-mcp-server
# GHIDRA_SERVER_PORT=13100
# GHIDRA_SERVER_USER=ai_analyst
# GHIDRA_SERVER_REPO=/shared
# GHIDRA_SERVER_PASSWORD=
# GHIDRA_SERVER_KEYSTORE=/root/.ghidra/ssh_key
# HOST_SSH_KEYSTORE=./ssh-keys  # Host directory with SSH keys

# ============================================
# Auto-Server Mode (NEW)
# ============================================
# Set PROJECT_MODE=auto-server to deploy bundled Ghidra Server
# This provides AI + GUI collaboration without external server setup

# Auto-generated SSH keys location (on host)
# AUTO_SERVER_SSH_DIR=~/.ghidra

# Default server repository name
# AUTO_SERVER_REPO=/mcp-projects

# Default server user
# AUTO_SERVER_USER=bridge

# Server resource limits
# GHIDRA_SERVER_MAXMEM=4G

# After starting in auto-server mode:
# - Server: localhost:13100
# - User: bridge (default)
# - SSH Key: ~/.ghidra/bridge_key (auto-generated)
# - Repository: /mcp-projects (default)
#
# Connect Ghidra GUI:
#   File → New Project → Shared Project
#   Server: localhost:13100
#   User: bridge
#   SSH Key: ~/.ghidra/bridge_key
#
# See .env.auto-server.example for a pre-configured template

# ============================================
# Advanced Options
# ============================================

# Auto-analyze binaries on import (true/false)
# AUTO_ANALYZE=false

# Analysis timeout in seconds
# ANALYZE_TIMEOUT=3600
