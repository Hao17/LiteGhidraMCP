# Ghidra MCP Bridge - Standalone Server Configuration
# Copy this file to .env.server and customize for your environment

# ============================================
# Version-Isolated Storage (required)
# ============================================
# Must match .env settings
GHIDRA_DATA_DIR=~/ghidra-data
GHIDRA_VERSION=12.0.3

# ============================================
# Server Configuration
# ============================================

# Server listening port
GHIDRA_SERVER_PORT=13100

# Default user (auto-created on first start)
SERVER_USER_NAME=bridge

# Default repository (auto-created on first start)
SERVER_REPO_NAME=/mcp-projects

# ============================================
# Data Paths (auto-managed via GHIDRA_DATA_DIR)
# ============================================
# Repos:      ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/repos     -> /repos
# SSH keys:   ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/ssh        -> /ssh
# Config:     ${GHIDRA_DATA_DIR}/${GHIDRA_VERSION}/config     -> /root/.ghidraServer
#
# SSH keys are auto-generated on first start.
# No manual key management needed.
