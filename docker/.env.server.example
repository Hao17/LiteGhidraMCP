# Ghidra MCP Bridge - Standalone Server Configuration
# Copy this file to .env.server and customize for your environment

# Server Port Configuration
GHIDRA_SERVER_PORT=13100

# Server Memory Limit
GHIDRA_SERVER_MAXMEM=4G

# SSH Key Directory (for PKI authentication)
# This directory will store auto-generated SSH keys
SERVER_SSH_DIR=./server-data/ssh

# Repository Name (default: /mcp-projects)
SERVER_REPO_NAME=/mcp-projects

# Default User Name (created during initialization)
SERVER_USER_NAME=bridge
