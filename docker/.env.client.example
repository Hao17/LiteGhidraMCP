# Ghidra MCP Bridge - Client Configuration
# Copy this file to .env.client and customize for your environment

# ============================================
# Client Identification (for multi-client)
# ============================================
CLIENT_CONTAINER_NAME=ghidra-mcp-bridge-client-1

# ============================================
# API Ports
# ============================================
CLIENT_MCP_PORT=8803        # HTTP API port
CLIENT_MCP_SSE_PORT=8804    # MCP SSE port

# For second client, use different ports:
# CLIENT_MCP_PORT=8813
# CLIENT_MCP_SSE_PORT=8814

# ============================================
# Project Configuration
# ============================================
PROJECT_NAME=default

# ============================================
# Ghidra Server Connection
# ============================================

# Server Host (Docker Network Mode)
GHIDRA_SERVER_HOST=ghidra-server

# For external server, use:
# GHIDRA_SERVER_HOST=host.docker.internal
# or external IP:
# GHIDRA_SERVER_HOST=192.168.1.100

GHIDRA_SERVER_PORT=13100
GHIDRA_SERVER_USER=bridge
GHIDRA_SERVER_REPO=/mcp-projects

# ============================================
# SSH Key Authentication
# ============================================
# Path to SSH private key (from server's SSH directory)
CLIENT_SSH_KEY_PATH=./server-data/ssh/bridge_key

# For external server, use absolute path:
# CLIENT_SSH_KEY_PATH=/path/to/keystore

# ============================================
# Logging
# ============================================
CLIENT_LOG_DIR=./logs/client-1
LOG_LEVEL=INFO

# For second client:
# CLIENT_LOG_DIR=./logs/client-2
